{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YourTokenHelper",
  "version": "0.0.0",
  "identifier": "com.yourtokenhelper.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run build:backend-sidecar",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YourTokenHelper",
        "width": 1120,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "externalBin": ["binaries/yth-backend"]
  }
}
